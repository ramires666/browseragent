# OWL Browser Agent — пример конфигурации
# Скопируй в .env и заполни свои значения

LLM_API_KEY=
API_URL=http://127.0.0.1:8080/v1/chat/completions
SCREENSHOT_PATH=browser_screen.jpg

# Путь к файлу с системным промптом (редактируй для смены инструкций модели)
SYSTEM_PROMPT_PATH=system_prompt.txt

# JSON Schema response_format (true/false)
JSON_SCHEMA_ENABLED=false

# Максимум токенов в ответе модели
MAX_TOKENS=800

# Пошаговый debug reCAPTCHA (true/false) — каждый шаг ждёт Enter
RECAPTCHA_DEBUG=false
